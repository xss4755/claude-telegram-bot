# Telegram Bot → Claude Code 配置
# 复制此文件为 .env 并填入真实值

# Telegram Bot Token（从 @BotFather 获取）
TG_BOT_TOKEN=your_bot_token_here

# 允许操作的 Telegram 用户 ID（逗号分隔，不知道ID先运行bot发 /id 命令）
TG_ALLOWED_IDS=123456789

# Claude Code 工作目录
CLAUDE_WORK_DIR=/Users/0xiaoyu/AI/duihua

# claude 可执行文件路径（which claude）
CLAUDE_BIN=/opt/homebrew/bin/claude

# 默认 Anthropic API Key（可选，也可只用 keys.json 配置）
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# 可选：自定义 base URL（中转/代理）
# ANTHROPIC_BASE_URL=https://your-proxy.com
